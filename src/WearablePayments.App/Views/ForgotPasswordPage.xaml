<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WearablePayments.App.Views.ForgotPasswordPage"
             Title="Reset Password">
    <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">
        <Label Text="Reset Password" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Label Text="Enter your email address and we'll send you a reset link."
               TextColor="Gray" HorizontalTextAlignment="Center" HorizontalOptions="Center"/>

        <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email"/>

        <Label Text="{Binding StatusMessage}"
               TextColor="{Binding IsSuccess, Converter={StaticResource BoolToColorConverter}}"
               IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
               HorizontalTextAlignment="Center"/>

        <Button Text="Send Reset Link"
                Command="{Binding SendResetCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"/>

        <Button Text="Back to Sign In"
                Command="{Binding BackToLoginCommand}"
                BackgroundColor="Transparent"
                TextColor="{AppThemeBinding Light=#0066CC, Dark=#4DA6FF}"
                BorderWidth="0"/>
    </VerticalStackLayout>
</ContentPage>
