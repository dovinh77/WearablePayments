<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WearablePayments.App.Views.RegisterPage"
             Title="Create Account">
    <VerticalStackLayout Padding="32" Spacing="16" VerticalOptions="Center">
        <Label Text="Create Account" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>
        <Label Text="Sign up to get started with Wearable Payments."
               TextColor="Gray" HorizontalTextAlignment="Center" HorizontalOptions="Center"/>

        <Entry Placeholder="Full Name" Text="{Binding FullName}"/>
        <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email"/>
        <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True"/>
        <Entry Placeholder="Confirm Password" Text="{Binding ConfirmPassword}" IsPassword="True"/>

        <Label Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
               HorizontalTextAlignment="Center"/>

        <Button Text="Create Account"
                Command="{Binding RegisterCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"/>

        <Button Text="Already have an account? Sign In"
                Command="{Binding BackToLoginCommand}"
                BackgroundColor="Transparent"
                TextColor="{AppThemeBinding Light=#0066CC, Dark=#4DA6FF}"
                BorderWidth="0"
                HorizontalOptions="Center"/>
    </VerticalStackLayout>
</ContentPage>
